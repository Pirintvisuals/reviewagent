# Anthropic Claude API Key
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Resend API Key for email sending
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Email address to send FROM (must be verified in Resend)
# For testing, use: onboarding@resend.dev
FROM_EMAIL=reviews@yourdomain.com

# Twilio credentials for WhatsApp messaging
# Get from: https://console.twilio.com
# TWILIO_WHATSAPP_NUMBER is the Twilio sandbox number, e.g. +14155238886
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# How many hours to wait before sending the review request after job completion
# Set to 0 to send within 15 minutes (still goes through the scheduler)
REVIEW_DELAY_HOURS=2

# JWT secret for auth tokens (generate a random string)
JWT_SECRET=change_this_to_a_random_secret_string_at_least_32_chars

# Port for backend server
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
